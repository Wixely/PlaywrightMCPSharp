{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PlaywrightMCPSharp": {
    "Server": {
      "Transport": "Http",
      "Host": "127.0.0.1",
      "Port": 5704,
      "Route": "/mcp",
      "AllowedHosts": [ "127.0.0.1", "localhost" ],
      "AllowedOrigins": []
    },
    "Security": {
      "Mode": "LocalOnly",
      "DangerousAllowRemoteNoAuth": false,
      "BearerToken": null
    },
    "Browser": {
      "BrowserType": "chromium",
      "Channel": null,
      "Headless": false,
      "SlowMoMs": 0,
      "ViewportWidth": 1440,
      "ViewportHeight": 900,
      "Locale": "en-GB",
      "TimezoneId": "Europe/London",
      "DeviceName": null,
      "DownloadsPath": "artifacts/downloads",
      "IgnoreHttpsErrors": false
    },
    "Session": {
      "IdleTimeout": "00:30:00",
      "MaxTabs": 8,
      "ArtifactRoot": "artifacts",
      "MaxConsoleEntries": 200,
      "MaxNetworkEntries": 500
    },
    "Features": {
      "Core": true,
      "Network": true,
      "Storage": true,
      "Devtools": true,
      "Testing": true,
      "Vision": true,
      "EnableRunCode": true,
      "AllowUnrestrictedFileAccess": false,
      "ClaudeCompatibleToolCatalog": false
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/playwrightmcp-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 52428800,
          "rollOnFileSizeLimit": true,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ]
  }
}
