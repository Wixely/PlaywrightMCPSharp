{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "restore",
      "type": "process",
      "command": "dotnet",
      "args": [
        "restore",
        "${workspaceFolder}/PlaywrightMCPSharp.sln"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/PlaywrightMCPSharp.sln",
        "-c",
        "Debug"
      ],
      "dependsOn": "restore",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/PlaywrightMCPSharp.Server/PlaywrightMCPSharp.Server.csproj",
        "--no-build"
      ],
      "dependsOn": "build",
      "problemMatcher": "$msCompile",
      "options": {
        "env": {
          "DOTNET_ENVIRONMENT": "Development",
          "ASPNETCORE_ENVIRONMENT": "Development",
          "PlaywrightMCPSharp__Server__Host": "127.0.0.1",
          "PlaywrightMCPSharp__Server__Port": "8931"
        }
      }
    },
    {
      "label": "run-stdio",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/PlaywrightMCPSharp.Server/PlaywrightMCPSharp.Server.csproj",
        "--no-build",
        "--",
        "--stdio"
      ],
      "dependsOn": "build",
      "problemMatcher": "$msCompile",
      "options": {
        "env": {
          "DOTNET_ENVIRONMENT": "Development",
          "ASPNETCORE_ENVIRONMENT": "Development"
        }
      }
    },
    {
      "label": "test",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/PlaywrightMCPSharp.sln",
        "-c",
        "Debug",
        "--no-build"
      ],
      "dependsOn": "build",
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "install-playwright-chromium",
      "type": "process",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/src/PlaywrightMCPSharp.Server/bin/Debug/net8.0/playwright.ps1",
        "install",
        "chromium"
      ],
      "dependsOn": "build",
      "problemMatcher": []
    }
  ]
}
