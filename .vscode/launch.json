{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug PlaywrightMCPSharp Server",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/PlaywrightMCPSharp.Server/bin/Debug/net8.0/PlaywrightMCPSharp.Server.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "env": {
        "DOTNET_ENVIRONMENT": "Development",
        "ASPNETCORE_ENVIRONMENT": "Development",
        "PlaywrightMCPSharp__Server__Host": "127.0.0.1",
        "PlaywrightMCPSharp__Server__Port": "8931"
      }
    },
    {
      "name": "Debug PlaywrightMCPSharp Server (stdio)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/PlaywrightMCPSharp.Server/bin/Debug/net8.0/PlaywrightMCPSharp.Server.dll",
      "args": [
        "--stdio"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "env": {
        "DOTNET_ENVIRONMENT": "Development",
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "Attach to PlaywrightMCPSharp Server",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}
